# Environment Configuration Example
# Copy this file to .env and fill in the values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# Database
DATABASE_PATH=../database/qera.db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# AI Service Configuration (for production)
OPENAI_API_KEY=
AI_SERVICE_PROVIDER=mock  # Set to 'openai' for production

# Logging
LOG_FORMAT=json  # Use 'json' for production, 'text' for development
LOG_FILE=logs/qera.log

# Environment
ENVIRONMENT=development  # Use 'production' for production deployment
