# Production Environment Configuration
# IMPORTANT: This file should NOT be committed to version control
# Use environment variables or secrets management in production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=WARNING

# Database (use absolute path or managed database service)
DATABASE_PATH=/app/data/qera.db

# JWT Configuration (CHANGE IN PRODUCTION)
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_KEY_512_BITS_MINIMUM
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# CORS Configuration (restrict to your domain)
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# AI Service Configuration
OPENAI_API_KEY=sk-your-openai-key-here
AI_SERVICE_PROVIDER=openai

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=/app/logs/qera.log
LOG_RETENTION_DAYS=30

# Environment
ENVIRONMENT=production

# Database Backup (optional)
BACKUP_ENABLED=true
BACKUP_PATH=/app/backups
BACKUP_SCHEDULE=daily

# Security
ALLOW_REGISTRATION=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT_MINUTES=15

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Monitoring (optional)
SENTRY_DSN=
DATADOG_API_KEY=
